SITE_URL=http://localhost:3000

# Required for Collectorfo (OpenSea developer key or free instant key)
OPENSEA_API_KEY=

# Optional Ethereum RPC for ENS resolve (default: publicnode)
# ETH_RPC_URL=https://ethereum.publicnode.com

# Progressive holder loading (only after user opts in)
# COLLECTORFO_MAX_COLLECTIONS=200
# COLLECTORFO_MAX_HOLDER_PAGES=100
# COLLECTORFO_HOLDER_PAGE_DELAY_MS=250
# COLLECTORFO_COLLECTION_GAP_MS=800
# COLLECTORFO_MAX_ENS_LOOKUPS=400
# Slow: also scan mint history for created collections not held
# COLLECTORFO_DEEP_MINT_SCAN=1

